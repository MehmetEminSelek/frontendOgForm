# =================================
# FRONTEND PRODUCTION - HOSTINGER
# =================================

# Production Mode
NODE_ENV=production
VITE_NODE_ENV=production

# API Configuration
VITE_API_BASE_URL="https://api.ogsiparis.com/api"
VITE_BACKEND_URL="https://api.ogsiparis.com"
VITE_BASE_URL="https://ogsiparis.com"

# WebSocket
VITE_WS_URL="wss://api.ogsiparis.com"

# App Info
VITE_APP_NAME="Ömer Güllü Sipariş Sistemi"
VITE_APP_VERSION="2.0.0"

# Security
VITE_CSRF_ENABLED=true
VITE_JWT_STORAGE_KEY="og_auth_token"
VITE_SESSION_TIMEOUT=28800000

# Features
VITE_ENABLE_CRM=true
VITE_ENABLE_REPORTS=true
VITE_ENABLE_NOTIFICATIONS=true

# Performance
VITE_CACHE_ENABLED=true
VITE_PAGINATION_SIZE=20

# Contact Info
VITE_COMPANY_NAME="Ömer Güllü"
VITE_COMPANY_PHONE="+90 XXX XXX XX XX"
VITE_COMPANY_EMAIL="info@ogsiparis.com"

# Build Settings
VITE_MINIFY=true
VITE_SOURCEMAP=false 